# ───────────────────────────────────────────────────────────────
# Infinity Interns — Environment Variables (root reference)
# Copy this file to .env and fill in real values for each service.
# ───────────────────────────────────────────────────────────────

# ── Core ───────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# ── Database (PostgreSQL) ──────────────────────────────────────
DATABASE_URL="postgresql://infinity:infinity@localhost:5432/infinity_interns?schema=public"

# ── Cache / Queues (Redis) ─────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth (JWT) ─────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_TTL="7d"

# ── OAuth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Object Storage (AWS S3 / Cloudflare R2) ────────────────────
STORAGE_PROVIDER=s3            # s3 | r2 | local
STORAGE_BUCKET=infinity-interns
STORAGE_REGION=ap-south-1
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_ENDPOINT=              # set for R2: https://<accountid>.r2.cloudflarestorage.com

# ── Notifications ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Infinity Interns <no-reply@infinityinterns.com>"
SMS_PROVIDER_KEY=
WHATSAPP_PROVIDER_KEY=

# ── Certificates ───────────────────────────────────────────────
CERT_SIGNING_PRIVATE_KEY=      # PEM (base64) used to digitally sign certificates
CERT_VERIFY_BASE_URL=http://localhost:3000/verify

# ── Public web (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME="Infinity Interns"
